generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"  // ใส่ URL ตรงๆ แบบนี้ได้เลยใน V.6
}

model Course {
  id          Int          @id @default(autoincrement())
  name        String
  students    Student[]
  attendances Attendance[]
}

model Student {
  id          Int          @id @default(autoincrement())
  studentCode String       @unique
  name        String
  // เก็บเป็น String ยาวๆ เพื่อบันทึก JSON ของ Array ตัวเลข 128 ตัว
  faceVector  String?      
  courseId    Int
  course      Course       @relation(fields: [courseId], references: [id])
  attendances Attendance[]
}

model Attendance {
  id        Int      @id @default(autoincrement())
  date      DateTime @default(now())
  status    String
  studentId Int
  student   Student  @relation(fields: [studentId], references: [id])
  courseId  Int
  course    Course   @relation(fields: [courseId], references: [id])
}